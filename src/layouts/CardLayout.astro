---
import Card from '../components/Card.astro';

type card = {title : string ; body : string ; href : string}

export interface Props {
    cardInfo : Array<card>
}

const { cardInfo } = Astro.props;

---

<div class=" relative bg-rose-500 mt-14" id="proj" slot="proj">
    <!-- <p class="text-center">Projects</p> -->
    <div class="w-[80%] grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3  gap-4  h-screen justify-center items-center  container mx-auto">
    {
        cardInfo.map((e) => 
            <Card body={e.body} href={e.href} title={e.title}></Card>
        )
    }
</div>

<div class="custom-shape-divider-top-1685083158 " >
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
    </svg>
  </div>
  <div class="wave " >
      <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
      </svg>
    </div>
  </div>
</div>

<style>


    .custom-shape-divider-top-1685083158 {
    position: absolute;
    top: 0;
    left: 0;

    width: 100%;
    overflow: hidden;
    line-height: 0;
}

.custom-shape-divider-top-1685083158 svg {
    position: relative;
    display: block;
    width: calc(120% + 1.3px);
    height: 269px;
    transform: rotateY(180deg);
}

.custom-shape-divider-top-1685083158 .shape-fill {
    fill: #A855F7;
}
    .wave {
        rotate: 180deg;
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
}

.wave svg {
    position: relative;
    display: block;
    width: calc(120% + 1.3px);
    height: 269px;
    transform: rotateY(180deg);
}

.wave .shape-fill {
    fill: #A855F7;
}


</style>