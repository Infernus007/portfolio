---
export interface Props {
  text: string;
  image: string;
}

const { text, image } = Astro.props;
---

<div class="relative">
  <div
    style="background-image: url('/stacked-layer.svg'); background-size: cover;"
  >
    <div class="flex items-center justify-center h-screen flex-col gap-3">
      <img src={image} class="w-[20%]" />
      <p class="text-white">{text}</p>
      <a href="https://www.linkedin.com/in/jash-naik-7612b8162">
        <button
          class="bg-blue-500 hover:bg-blue-400 text-white font-bold py-2 px-4 border-b-4 border-blue-700 hover:border-blue-500 rounded"
        >
          Get in touch
        </button>
      </a>
    </div>
  </div>
</div>

<script>
  //@ts-ignore
  let paths: SVGPathElement[] = document.querySelectorAll(".animated-svg path");

  paths.forEach((e: SVGPathElement) => {
    console.log(e.getTotalLength());
    e.style.strokeDasharray = e.getTotalLength() as unknown as string;
    e.style.strokeDashoffset = e.getTotalLength() as unknown as string;
  });
</script>
